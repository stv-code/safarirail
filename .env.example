# SafariRail - Sanity environment variables
# Copy this to .env.local and add the same values to your hosting provider.

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
NEXT_PUBLIC_SANITY_STUDIO_URL=/studio
NEXT_PUBLIC_SITE_URL=https://safarirail.co.ke

# Required for draft preview and Presentation Tool.
SANITY_API_READ_TOKEN=your_read_token_here

# Required for the /api/revalidate-tag webhook route.
SANITY_REVALIDATE_SECRET=your_revalidation_secret_here

# Optional: published-content browser token for faster live preview.
NEXT_PUBLIC_SANITY_BROWSER_TOKEN=
