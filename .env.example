PUBLIC_SITE_URL=https://safarirail.co.ke

# Required by api/bookings.ts on Vercel.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Required for field-level encryption of passport/ID values before persistence.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PASSPORT_ID_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Optional durable production rate limiting. Without these, local in-memory fallback is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
