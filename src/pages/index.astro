---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import BookingPanel from '../components/BookingPanel.astro'
import Footer from '../components/Footer.astro'
import { bookingExperience, formatKes, paymentMethods, siteConfig, ticketClasses, whatsappBaseUrl } from '../config/business'

const infoStrip = [
  'Independent booking assistance for travellers without M-Pesa',
  bookingExperience.responseTimeLabel,
  'Tickets delivered via Email, WhatsApp or Telegram',
]

const faqs = [
  ['Are you the official SGR website?', 'No. We are a private third-party agency helping tourists book tickets. We are NOT selling tickets - we assist you in booking them. The official website is metickets.krc.co.ke.'],
  ['How do I receive my ticket?', 'After booking, we send the M-Pesa message and ticket number to your email, WhatsApp, or Telegram. You MUST use this message to physically print your ticket at the station before boarding.'],
  ['What payment methods do you accept?', 'We accept Wise, Remitly, Sendwave, and Western Union (all remitted to M-Pesa), as well as USDT, BTC, and BNB crypto.'],
  ['What is your refund and cancellation policy?', 'We do not handle refunds. Cancellation is strictly handled by Kenya Railways in person at the station.'],
  ['Do children travel for free?', 'Children under 3 years travel free. Children aged 3-11 pay a reduced child fare.'],
]
---

<BaseLayout>
  <main>
    <section class="hero">
      <Header />
      <div class="hero-content">
        <p class="eyebrow">Madaraka Express - Nairobi to Mombasa</p>
        <h1>Experience Kenya <em>by Rail</em></h1>
        <p class="hero-copy">
          The hassle-free way for tourists to book SGR tickets. No M-Pesa? No Kenyan bank account? No problem.
        </p>
        <p class="hero-caveat">
          Independent third-party assistance. Prefer to book directly? Use the official KRC site.
        </p>
        <div class="hero-actions">
          <a class="primary-button" href="#pricing">View Prices</a>
          <a class="ghost-button" href="#how-it-works">How It Works</a>
        </div>
      </div>
      <div class="hero-bottom" id="booking">
        <section class="booking-flow" id="how-it-works" aria-labelledby="how-it-works-title">
          <div class="section-heading compact-flow-heading">
            <p class="eyebrow">How It Works</p>
            <div>
              <h2 id="how-it-works-title">Request first. Pay after we confirm.</h2>
              <p>{bookingExperience.responseTimeLabel}</p>
            </div>
          </div>
          <div class="process-grid">
            {bookingExperience.steps.map((step, index) => (
              <article>
                <span>{index + 1}</span>
                <p>{step}</p>
              </article>
            ))}
          </div>
        </section>
        <BookingPanel />
      </div>
    </section>

    <section class="info-strip">
      {infoStrip.map((item) => <span>{item}</span>)}
    </section>

    <section class="section pricing-section" id="pricing">
      <div class="section-heading">
        <p class="eyebrow">Ticket Classes</p>
        <div>
          <h2>Choose Your Journey</h2>
          <p>All prices include our booking assistance fee. Select the class that suits your travel style.</p>
        </div>
      </div>
      <div class="pricing-grid">
        {ticketClasses.map((tier) => (
          <article class={`pricing-card ${tier.badge ? 'featured' : ''}`}>
            {tier.badge && <p class="pricing-badge">{tier.badge}</p>}
            <h3>{tier.label}</h3>
            <div class="price"><sup>KES</sup> {formatKes(tier.adultPrice)}</div>
            <p class="price-unit">per adult</p>
            <div class="fare-breakdown">
              <strong>Fare Breakdown</strong>
              <span>Adult: {formatKes(tier.adultPrice)} (ticket {formatKes(tier.ticketAdult)} + service {formatKes(tier.service)})</span>
              <span>Child (3-11): {formatKes(tier.childPrice)} (ticket {formatKes(tier.ticketChild)} + service {formatKes(tier.service)})</span>
              <span>Child (&lt;3): Free</span>
            </div>
            <ul>
              {tier.features.map((feature) => <li>{feature}</li>)}
            </ul>
            <button class="primary-button pricing-select" type="button" data-ticket-class={tier.label}>Submit Booking Request</button>
          </article>
        ))}
      </div>
    </section>

    <section class="image-feature">
      <div>
        <p class="eyebrow">Ticket delivery</p>
        <h2>We send the M-Pesa message and ticket number.</h2>
        <p>
          After booking, your details are sent to your email, WhatsApp, or Telegram. You must use that message to physically print your ticket at the station before boarding.
        </p>
      </div>
    </section>

    <section class="section payment-section">
      <div class="section-heading">
        <p class="eyebrow">Secure Payment</p>
        <div>
          <h2>Choose your payment method</h2>
          <p>Submit your booking request first, then follow the payment instructions we confirm. Tickets are sent after payment is received. User is responsible for any transfer delays.</p>
        </div>
      </div>
      <div class="payment-grid">
        {paymentMethods.map(({ method, detail }) => (
          <article>
            <h3>{method}</h3>
            <p>{detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section faq-section" id="faq">
      <div class="section-heading">
        <p class="eyebrow">Common Questions</p>
        <div>
          <h2>Frequently Asked</h2>
          <p>Everything you need to know before booking with us.</p>
        </div>
      </div>
      <div class="faq-list">
        {faqs.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
      <p class="official-faq">
        More questions? <a href={siteConfig.officialKrcFaqUrl} target="_blank" rel="noopener noreferrer">View official KRC FAQs</a>
      </p>
    </section>

    <section class="section contact-section" id="contact">
      <div class="section-heading">
        <p class="eyebrow">Get in Touch</p>
        <div>
          <h2>Need Help?</h2>
          <p>Custom itineraries, group bookings, or general questions.</p>
        </div>
      </div>
      <div class="contact-grid">
        <div class="contact-card">
          <h3>Email</h3>
          <a href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>
        </div>
        <div class="contact-card">
          <h3>WhatsApp</h3>
          <a href={whatsappBaseUrl} target="_blank" rel="noopener noreferrer">{siteConfig.whatsappDisplay}</a>
        </div>
        <div class="fraud-alert">
          <strong>Fraud Alert:</strong>
          If you suspect fraudulent activity in our name, contact DCI Kenya, call 911, or visit the nearest police station immediately.
        </div>
      </div>
      <form class="contact-form" id="contact-form">
        <div class="field">
          <label for="contact-name">Your Name</label>
          <input id="contact-name" name="name" type="text" placeholder="John Smith" required />
        </div>
        <div class="field">
          <label for="contact-email">Email Address</label>
          <input id="contact-email" name="email" type="email" placeholder="john@example.com" required />
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="I need help with a group booking for..." required></textarea>
        </div>
        <button class="primary-button" type="submit">Send Message</button>
      </form>
    </section>

    <section class="cta-section">
      <div>
        <p class="eyebrow">Booking Confirmed?</p>
        <h2>Your M-Pesa ticket message will be sent after payment is confirmed.</h2>
      </div>
      <a class="primary-button" href="#booking">Submit Booking Request</a>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script is:inline define:vars={{ supportEmail: siteConfig.supportEmail }}>
  const contactForm = document.querySelector('#contact-form')

  contactForm?.addEventListener('submit', (submitEvent) => {
    submitEvent.preventDefault()

    if (!(contactForm instanceof HTMLFormElement)) return

    const data = new FormData(contactForm)
    const name = data.get('name') || ''
    const email = data.get('email') || ''
    const message = data.get('message') || ''
    const body = [`Name: ${name}`, `Email: ${email}`, '', String(message)].join('\n')

    window.location.href = `mailto:${supportEmail}?subject=SafariRail%20Message&body=${encodeURIComponent(body)}`
  })

  document.querySelectorAll('.pricing-select').forEach((button) => {
    button.addEventListener('click', () => {
      if (!(button instanceof HTMLElement)) return
      const selectedClass = button.dataset.ticketClass
      const classInput = document.querySelector('#class')
      const bookingForm = document.querySelector('#booking-panel')
      if (selectedClass && classInput instanceof HTMLSelectElement) {
        classInput.value = selectedClass
        classInput.dispatchEvent(new Event('change', { bubbles: true }))
      }
      bookingForm?.scrollIntoView({ behavior: 'smooth', block: 'start' })
    })
  })
</script>
