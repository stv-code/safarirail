---
import { siteConfig, whatsappBaseUrl } from '@/config/site'
---

<footer class="site-footer" id="contact">
  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href="/" aria-label="SafariRail home">
        <img class="brand-logo" src="/safarirail.png" alt="SafariRail" width="1680" height="1024" loading="lazy" decoding="async" />
      </a>
      <p>
        SafariRail is an independent third-party booking agency. Not affiliated with, endorsed by, or representing Kenya Railways Corporation (KRC).
      </p>
      <a href={siteConfig.officialKrcUrl} target="_blank" rel="noopener noreferrer">Official KRC site: metickets.krc.co.ke</a>
    </div>
    <div>
      <h2>Talk to us</h2>
      <a href={whatsappBaseUrl} target="_blank" rel="noopener noreferrer">WhatsApp: {siteConfig.whatsappDisplay}</a>
      <a href={`mailto:${siteConfig.supportEmail}`}>{siteConfig.supportEmail}</a>
      <span>Nairobi, Kenya</span>
    </div>
    <div>
      <h2>Footer navigation</h2>
      <a href="/#pricing">Classes</a>
      <a href="/reviews">Reviews</a>
      <a href="/#faq">FAQ</a>
      <a href="/#contact">Contact</a>
    </div>
  </div>
  <p class="footer-note">
    SafariRail is an independent third-party booking agency. Not affiliated with Kenya Railways Corporation.
  </p>
</footer>
