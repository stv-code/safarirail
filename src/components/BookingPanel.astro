---
import countries from '@/data/countries.json'
import { departures, formatKes, siteConfig, ticketClasses } from '@/config/business'
---

<form class="booking-panel booking-panel-full" id="booking-panel">
  <div class="booking-summary">
    <p class="eyebrow">Passenger Details</p>
    <h2>Request SGR booking assistance</h2>
    <p>
      Ticket message sent to your email/WhatsApp after payment confirmation. You must print it at the station.
    </p>
  </div>

  <div class="field">
    <label for="class">Class</label>
    <select id="class" name="class">
      {ticketClasses.map((ticketClass) => (
        <option value={ticketClass.label} data-adult={ticketClass.adultPrice} data-child={ticketClass.childPrice}>
          {ticketClass.label} - KES {formatKes(ticketClass.adultPrice)} adult
        </option>
      ))}
    </select>
  </div>
  <div class="field">
    <label for="date">Travel Date</label>
    <input id="date" name="date" type="date" required />
  </div>
  <div class="field">
    <label for="departure">Preferred Departure</label>
    <select id="departure" name="departure">
      {departures.map((departure) => <option value={departure}>{departure}</option>)}
    </select>
  </div>
  <div class="field">
    <label for="adults">Adults</label>
    <select id="adults" name="adults">
      {[1, 2, 3, 4, 5, 6].map((number) => <option value={number}>{number}</option>)}
    </select>
  </div>
  <div class="field">
    <label for="children">Children (3-11)</label>
    <select id="children" name="children">
      {[0, 1, 2, 3, 4].map((number) => <option value={number}>{number}</option>)}
    </select>
  </div>
  <div class="field">
    <label for="name">Full Name (as per Passport)</label>
    <input id="name" name="name" type="text" autocomplete="name" minlength="2" maxlength="120" placeholder="e.g. John Michael Smith" required />
  </div>
  <div class="field">
    <label for="passport">Passport / ID Number</label>
    <input id="passport" name="passport" type="text" autocomplete="off" minlength="3" maxlength="80" required />
  </div>
  <div class="field">
    <label for="gender">Gender</label>
    <select id="gender" name="gender" required>
      <option value="">Select</option>
      <option value="Male">Male</option>
      <option value="Female">Female</option>
    </select>
  </div>
  <div class="field">
    <label for="country">Country of Origin</label>
    <select id="country" name="country" required>
      <option value="">Select Country</option>
      {countries.map((country) => <option value={country['alpha-2']}>{country.name}</option>)}
    </select>
  </div>
  <div class="field">
    <label for="email">Email Address</label>
    <input id="email" name="email" type="email" autocomplete="email" placeholder="tickets@example.com" required />
  </div>
  <div class="privacy-consent">
    <input id="privacy-consent" name="consent" type="checkbox" required />
    <label for="privacy-consent">
      I consent to SafariRail storing my booking and passenger identity details only to process this request.
      Passport/ID details are retained temporarily for booking support and can be deleted on request.
      <a href={siteConfig.privacyPolicyUrl}>Privacy policy</a>
    </label>
  </div>
  <p class="form-status" id="booking-status" role="status" aria-live="polite"></p>
  <div class="booking-total">
    <span>Estimated Total</span>
    <strong id="booking-total">KES 2,000</strong>
    <small>Children under 3 travel free.</small>
  </div>
  <button class="primary-button" type="submit">Submit Secure Booking Request</button>
</form>

<script>
  const form = document.querySelector('#booking-panel')
  const dateInput = document.querySelector('#date')
  const classInput = document.querySelector('#class')
  const adultsInput = document.querySelector('#adults')
  const childrenInput = document.querySelector('#children')
  const totalOutput = document.querySelector('#booking-total')
  const statusOutput = document.querySelector('#booking-status')
  const submitButton = form?.querySelector('button[type="submit"]')

  function getSelectedClass() {
    if (!(classInput instanceof HTMLSelectElement)) return null
    return classInput.selectedOptions[0]
  }

  function calculateTotal() {
    const selectedClass = getSelectedClass()
    if (!selectedClass || !(adultsInput instanceof HTMLSelectElement) || !(childrenInput instanceof HTMLSelectElement)) return 0

    const adultPrice = Number(selectedClass.dataset.adult || 0)
    const childPrice = Number(selectedClass.dataset.child || 0)
    const adults = Number(adultsInput.value || 1)
    const children = Number(childrenInput.value || 0)

    return adults * adultPrice + children * childPrice
  }

  function updateTotal() {
    if (!(totalOutput instanceof HTMLElement)) return
    totalOutput.textContent = `KES ${calculateTotal().toLocaleString()}`
  }

  function setStatus(message: string, isError = false) {
    if (!(statusOutput instanceof HTMLElement)) return
    statusOutput.textContent = message
    statusOutput.dataset.status = isError ? 'error' : 'success'
  }

  function getCountryLabel(countryCode: string) {
    const countryInput = document.querySelector('#country')
    if (!(countryInput instanceof HTMLSelectElement)) return countryCode
    return countryInput.selectedOptions[0]?.textContent || countryCode
  }

  if (dateInput instanceof HTMLInputElement) {
    dateInput.min = new Date().toISOString().split('T')[0]
  }

  classInput?.addEventListener('change', updateTotal)
  adultsInput?.addEventListener('change', updateTotal)
  childrenInput?.addEventListener('change', updateTotal)
  updateTotal()

  form?.addEventListener('submit', async (event) => {
    event.preventDefault()

    if (!(form instanceof HTMLFormElement)) return
    if (!form.reportValidity()) return

    const data = new FormData(form)
    const payload = {
      travelClass: data.get('class'),
      travelDate: data.get('date'),
      departure: data.get('departure'),
      adults: Number(data.get('adults') || 1),
      children: Number(data.get('children') || 0),
      fullName: data.get('name'),
      passportId: data.get('passport'),
      gender: data.get('gender'),
      countryCode: data.get('country'),
      countryName: getCountryLabel(String(data.get('country') || '')),
      email: data.get('email'),
      consent: data.get('consent') === 'on',
    }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true
        submitButton.textContent = 'Submitting securely...'
      }
    setStatus('Submitting your secure booking request...')

    try {
      const response = await fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
      const result = await response.json()

      if (!response.ok) {
        const details = Array.isArray(result.errors) ? ` ${result.errors.join(' ')}` : ''
        throw new Error(`${result.message || 'Submission failed.'}${details}`)
      }

      setStatus(`Booking request ${result.bookingReference} recorded securely. Opening WhatsApp with your reference only.`)
      if (typeof result.whatsappUrl === 'string') {
        window.open(result.whatsappUrl, '_blank', 'noopener,noreferrer')
      }
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'We could not submit your booking right now. Please try again.', true)
    } finally {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false
        submitButton.textContent = 'Submit Secure Booking Request'
      }
    }
  })
</script>
